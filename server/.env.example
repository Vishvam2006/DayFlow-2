PORT=5001
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_KEY=replace-with-a-long-random-secret

# Frontend / app URLs used in emails and CORS.
APP_URL=https://your-frontend.onrender.com
EMPLOYEE_DASHBOARD_URL=https://your-frontend.onrender.com/#/employee-dashboard/leave-request
EMPLOYEE_TASKS_URL=https://your-frontend.onrender.com/#/employee-dashboard/tasks
CORS_ORIGINS=https://your-frontend.onrender.com

# Resend email delivery
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=DayFlow HRMS <no-reply@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com
EMAIL_APP_NAME=DayFlow HRMS
EMAIL_RETRY_ATTEMPTS=2
EMAIL_RETRY_DELAY_MS=750

# Email / OTP delivery behavior
LEAVE_NOTIFICATION_RETRY_DELAY_MS=60000

# Attendance automation
ATTENDANCE_AUTOMATION_ENABLED=true
ATTENDANCE_AUTOMATION_TZ=Asia/Kolkata
ATTENDANCE_AUTOMATION_RUN_AT=00:30
ATTENDANCE_AUTOMATION_CHECK_INTERVAL_MS=60000
ATTENDANCE_LATE_AFTER_HOUR=10
ATTENDANCE_LATE_AFTER_MINUTE=15

# Cloudinary profile uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=dayflow_profiles

# Analytics
GROQ_API_KEY=your-groq-api-key
ANALYTICS_WINDOW_DAYS=30
ANALYTICS_BASELINE_DAYS=90
ANALYTICS_AI_BATCH_SIZE=10
ANALYTICS_CACHE_TTL_DAYS=14

# Bot integration
BOT_SECRET_KEY=replace-with-shared-secret
